# All variables are optional — sensible defaults are provided via Zod validation.

# Modrinth API Configuration
MODRINTH_API_URL=https://api.modrinth.com
MODRINTH_USER_AGENT=AriadnesThread/1.0.0 (https://github.com/desaianand1/Ariadnes-Thread)

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=300
RESET_INTERVAL_SECONDS=60

# Retry Configuration
MAX_RETRIES=3
RETRY_DELAY_MS=1000
RETRY_BACKOFF_STRATEGY=exponential

# Download Configuration
MAX_CONCURRENT_DOWNLOADS=5

# Network
FETCH_TIMEOUT_MS=30000

# Optional Services
# RESEND_API_KEY=re_xxxxxxxxxxxx
